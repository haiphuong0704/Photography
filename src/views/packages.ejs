<!DOCTYPE html>
<html lang="vi">
<head><%- include('partials/head') %></head>
<body>

<%- include('partials/loader') %>
<%- include('partials/nav') %>

<!-- ============================================================
     PAGE HERO
     ============================================================ -->
<header class="page-hero pkg-hero">
  <div class="pkg-hero-bg" aria-hidden="true">
    <div class="pkg-hero-bg-img" style="background-image:url('https://images.unsplash.com/photo-1604017011826-d3b4c23f8914?w=1800&h=1000&fit=crop&auto=format&q=80')"></div>
    <div class="pkg-hero-bg-grain"></div>
  </div>

  <div class="wrap pkg-hero-inner">
    <div class="pkg-hero-text">
      <span class="eyebrow"
        data-vi="Dịch vụ & Định giá"
        data-en="Services & Pricing">Dịch vụ & Định giá</span>
      <h1 class="display page-hero-title reveal" data-chars
        data-vi="BẢNG GIÁ."
        data-en="PRICING.">BẢNG GIÁ.</h1>
      <p class="page-hero-sub reveal"
        data-vi="Minh bạch — không phụ phí ẩn.<br>Chọn gói phù hợp, đặt lịch trong 2 phút."
        data-en="Transparent — no hidden fees.<br>Pick your package, book in 2 minutes.">Minh bạch — không phụ phí ẩn.<br>Chọn gói phù hợp, đặt lịch trong 2 phút.</p>
      <div class="pkg-hero-meta mono reveal">
        <span data-vi="03 gói dịch vụ" data-en="03 packages">03 gói dịch vụ</span>
        <span class="pkg-hero-dot"></span>
        <span>Sài Gòn · Hà Nội · Đà Nẵng</span>
        <span class="pkg-hero-dot"></span>
        <span data-vi="Tư vấn miễn phí" data-en="Free consultation">Tư vấn miễn phí</span>
      </div>
    </div>
    <div class="pkg-hero-visual reveal">
      <div class="pkg-hero-stat">
        <span class="display pkg-hero-stat-val" data-target="86">0</span>
        <span class="mono" data-vi="đám cưới" data-en="weddings">đám cưới</span>
      </div>
      <div class="pkg-hero-stat">
        <span class="display pkg-hero-stat-val" data-target="230">0</span>
        <span class="mono" data-vi="buổi chụp" data-en="sessions">buổi chụp</span>
      </div>
      <div class="pkg-hero-stat">
        <span class="display pkg-hero-stat-val" data-target="8">0</span>
        <span class="mono" data-vi="năm kinh nghiệm" data-en="years exp.">năm kinh nghiệm</span>
      </div>
      <div class="pkg-hero-promise mono"
        data-vi='"Không phụ phí ẩn. Không bất ngờ."'
        data-en='"No hidden fees. No surprises."'>"Không phụ phí ẩn. Không bất ngờ."</div>
    </div>
  </div>
</header>

<!-- ============================================================
     QUY TRÌNH
     ============================================================ -->
<section class="process-section">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow" data-vi="Cách hoạt động" data-en="How it works">Cách hoạt động</span>
      <h2 class="display section-title"
        data-vi="QUY TRÌNH<br>4 BƯỚC."
        data-en="4-STEP<br>PROCESS.">QUY TRÌNH<br>4 BƯỚC.</h2>
    </div>
    <div class="process-grid stagger">

      <div class="process-step reveal">
        <div class="frame process-frame">
          <div class="frame-img" style="--ar:3/4;" data-photo="https://images.unsplash.com/photo-1552699611-e2c208d5d9cf?w=400&h=533&fit=crop&auto=format&q=80"></div>
          <div class="frame-meta">
            <span data-vi="Tư vấn" data-en="Consult">Tư vấn</span>
            <span class="num">P01</span>
          </div>
        </div>
        <span class="process-num mono">01</span>
        <div class="process-body">
          <h3 class="display process-title" data-vi="TƯ VẤN" data-en="CONSULT">TƯ VẤN</h3>
          <p class="process-desc"
            data-vi="Kể ý tưởng — chúng tôi tư vấn phong cách, địa điểm và gói phù hợp. Miễn phí, không ràng buộc."
            data-en="Share your ideas — we advise on style, location and the right package. Free, no commitment.">Kể ý tưởng — chúng tôi tư vấn phong cách, địa điểm và gói phù hợp. Miễn phí, không ràng buộc.</p>
        </div>
      </div>

      <div class="process-step reveal">
        <div class="frame process-frame">
          <div class="frame-img" style="--ar:3/4;" data-photo="https://images.unsplash.com/photo-1533091090875-1ff4acc497dd?w=400&h=533&fit=crop&auto=format&q=80"></div>
          <div class="frame-meta">
            <span data-vi="Đặt lịch" data-en="Book">Đặt lịch</span>
            <span class="num">P02</span>
          </div>
        </div>
        <span class="process-num mono">02</span>
        <div class="process-body">
          <h3 class="display process-title" data-vi="ĐẶT LỊCH" data-en="BOOK">ĐẶT LỊCH</h3>
          <p class="process-desc"
            data-vi="Xác nhận ngày, đặt cọc 50% qua chuyển khoản. Lịch được giữ ngay sau khi nhận cọc."
            data-en="Confirm the date, pay 50% deposit by bank transfer. Slot reserved immediately upon receipt.">Xác nhận ngày, đặt cọc 50% qua chuyển khoản. Lịch được giữ ngay sau khi nhận cọc.</p>
        </div>
      </div>

      <div class="process-step reveal">
        <div class="frame process-frame">
          <div class="frame-img" style="--ar:3/4;" data-photo="https://images.unsplash.com/photo-1622277430358-f4d134452e2e?w=400&h=533&fit=crop&auto=format&q=80"></div>
          <div class="frame-meta">
            <span data-vi="Buổi chụp" data-en="Shoot">Buổi chụp</span>
            <span class="num">P03</span>
          </div>
        </div>
        <span class="process-num mono">03</span>
        <div class="process-body">
          <h3 class="display process-title" data-vi="BUỔI CHỤP" data-en="SHOOT">BUỔI CHỤP</h3>
          <p class="process-desc"
            data-vi="Chụp tự nhiên, không dàn dựng cứng nhắc. Chúng tôi dẫn dắt — bạn chỉ cần là chính mình."
            data-en="Natural, unscripted photography. We guide — you just be yourself.">Chụp tự nhiên, không dàn dựng cứng nhắc. Chúng tôi dẫn dắt — bạn chỉ cần là chính mình.</p>
        </div>
      </div>

      <div class="process-step reveal">
        <div class="frame process-frame">
          <div class="frame-img" style="--ar:3/4;" data-photo="https://images.unsplash.com/photo-1487528001669-63c47a53fd39?w=400&h=533&fit=crop&auto=format&q=80"></div>
          <div class="frame-meta">
            <span data-vi="Nhận ảnh" data-en="Receive">Nhận ảnh</span>
            <span class="num">P04</span>
          </div>
        </div>
        <span class="process-num mono">04</span>
        <div class="process-body">
          <h3 class="display process-title" data-vi="NHẬN ẢNH" data-en="RECEIVE">NHẬN ẢNH</h3>
          <p class="process-desc"
            data-vi="Ảnh chỉnh sửa giao qua Google Drive private. Đúng hạn, đúng phong cách đã thống nhất."
            data-en="Edited photos delivered via private Google Drive. On time, true to the agreed style.">Ảnh chỉnh sửa giao qua Google Drive private. Đúng hạn, đúng phong cách đã thống nhất.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ============================================================
     PACKAGES GRID
     ============================================================ -->
<section class="packages-section">
  <div class="wrap">

    <div class="packages-grid">
      <% packages.forEach((pkg, i) => { %>
      <div class="pkg-card reveal<%= pkg.highlighted ? ' pkg-card--highlight' : '' %> pkg-card--<%= pkg.id %>">

        <div class="pkg-film-holes" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>

        <div class="pkg-inner">

          <div class="pkg-num-row">
            <span class="pkg-num mono">0<%= i+1 %> / 03</span>
            <% if (pkg.highlighted) { %>
            <span class="pkg-badge mono"
              data-vi="★ ĐỀ XUẤT"
              data-en="★ RECOMMENDED">★ ĐỀ XUẤT</span>
            <% } %>
          </div>

          <div class="pkg-header">
            <h2 class="display pkg-name"><%= pkg.name %></h2>
            <p class="pkg-tagline mono"
              data-vi="<%= pkg.tagline %>"
              data-en="<%= pkg.enTagline %>"><%= pkg.tagline %></p>
          </div>

          <div class="pkg-specs">
            <div class="pkg-spec">
              <span class="pkg-spec-label mono"
                data-vi="Thời gian" data-en="Duration">Thời gian</span>
              <span class="pkg-spec-val"
                data-vi="<%= pkg.duration %>"
                data-en="<%= pkg.enDuration %>"><%= pkg.duration %></span>
            </div>
            <div class="pkg-spec">
              <span class="pkg-spec-label mono"
                data-vi="Số ảnh" data-en="Photos">Số ảnh</span>
              <span class="pkg-spec-val"
                data-vi="<%= pkg.photos %>"
                data-en="<%= pkg.enPhotos %>"><%= pkg.photos %></span>
            </div>
            <div class="pkg-spec">
              <span class="pkg-spec-label mono"
                data-vi="Giao ảnh" data-en="Delivery">Giao ảnh</span>
              <span class="pkg-spec-val"
                data-vi="<%= pkg.delivery.replace('Giao trong ','') %>"
                data-en="<%= pkg.enDelivery %>"><%= pkg.delivery.replace('Giao trong ','') %></span>
            </div>
          </div>

          <div class="pkg-price-block">
            <span class="pkg-price-val"><%= pkg.priceLabel %></span>
            <span class="pkg-price-note mono"
              data-vi="trọn gói" data-en="all-inclusive">trọn gói</span>
          </div>

          <div class="pkg-rule"></div>

          <ul class="pkg-features">
            <% pkg.features.forEach((f, fi) => { %>
            <li>
              <span class="pkg-dot" aria-hidden="true"></span>
              <span data-vi="<%= f %>" data-en="<%= pkg.enFeatures[fi] %>"><%= f %></span>
            </li>
            <% }) %>
          </ul>

          <% if (pkg.extras.length) { %>
          <div class="pkg-extras">
            <% pkg.extras.forEach((e, ei) => { %>
            <span class="mono pkg-extra-item"
              data-vi="↳ <%= e %>"
              data-en="↳ <%= pkg.enExtras[ei] %>">↳ <%= e %></span>
            <% }) %>
          </div>
          <% } %>

          <a href="/booking?package=<%= pkg.id %>"
             class="btn<%= pkg.highlighted ? ' btn-volt' : ' btn-on-dark' %> pkg-cta"
             data-vi="<%= pkg.cta %> →"
             data-en="<%= pkg.enCta %> →"><%= pkg.cta %> →</a>

        </div>
      </div>
      <% }) %>
    </div>

    <!-- Who fits -->
    <div class="who-fits reveal">
      <div class="who-fits-label mono"
        data-vi="Gói nào phù hợp với bạn?"
        data-en="Which package fits you?">Gói nào phù hợp với bạn?</div>
      <div class="who-fits-grid">
        <div class="who-fits-col">
          <span class="who-fits-pkg mono">STANDARD</span>
          <ul class="who-fits-list">
            <li data-vi="Chân dung cá nhân"   data-en="Personal portrait">Chân dung cá nhân</li>
            <li data-vi="Sinh nhật / Kỷ niệm" data-en="Birthday / Anniversary">Sinh nhật / Kỷ niệm</li>
            <li data-vi="Headshot doanh nghiệp" data-en="Business headshot">Headshot doanh nghiệp</li>
            <li data-vi="Lifestyle nhẹ nhàng"  data-en="Casual lifestyle">Lifestyle nhẹ nhàng</li>
          </ul>
        </div>
        <div class="who-fits-col who-fits-col--mid">
          <span class="who-fits-pkg mono">SIGNATURE ★</span>
          <ul class="who-fits-list">
            <li data-vi="Pre-wedding & Cưới nhỏ" data-en="Pre-wedding & Intimate wedding">Pre-wedding & Cưới nhỏ</li>
            <li data-vi="Editorial / Thời trang"  data-en="Editorial / Fashion">Editorial / Thời trang</li>
            <li data-vi="Brand photoshoot"         data-en="Brand photoshoot">Brand photoshoot</li>
            <li data-vi="Gia đình & Maternity"     data-en="Family & Maternity">Gia đình & Maternity</li>
          </ul>
        </div>
        <div class="who-fits-col">
          <span class="who-fits-pkg mono">PREMIUM</span>
          <ul class="who-fits-list">
            <li data-vi="Đám cưới toàn ngày"  data-en="Full-day wedding">Đám cưới toàn ngày</li>
            <li data-vi="Commercial campaign" data-en="Commercial campaign">Commercial campaign</li>
            <li data-vi="Sự kiện lớn"         data-en="Large event">Sự kiện lớn</li>
            <li data-vi="Full production"     data-en="Full production">Full production</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Add-ons menu -->
    <div class="pkg-addons reveal">
      <div class="pkg-addons-head">
        <h3 class="display pkg-addons-title"
          data-vi="DỊCH VỤ BỔ SUNG"
          data-en="ADD-ONS">DỊCH VỤ BỔ SUNG</h3>
        <span class="mono pkg-addons-sub"
          data-vi="Thêm vào bất kỳ gói nào"
          data-en="Add to any package">Thêm vào bất kỳ gói nào</span>
      </div>
      <div class="pkg-menu">
        <div class="pkg-menu-item">
          <span class="pkg-menu-name mono"
            data-vi="In ảnh thêm"
            data-en="Extra prints">In ảnh thêm</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <span class="pkg-menu-price"
            data-vi="200.000 ₫ / tấm (20×30)"
            data-en="200.000 ₫ / print (20×30)">200.000 ₫ / tấm (20×30)</span>
        </div>
        <div class="pkg-menu-item">
          <span class="pkg-menu-name mono">Rush delivery</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <span class="pkg-menu-price"
            data-vi="+500.000 ₫ (trong 48h)"
            data-en="+500.000 ₫ (within 48h)">+500.000 ₫ (trong 48h)</span>
        </div>
        <div class="pkg-menu-item">
          <span class="pkg-menu-name mono"
            data-vi="Di chuyển ngoại thành"
            data-en="Out-of-city travel">Di chuyển ngoại thành</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <span class="pkg-menu-price">+300.000 – 800.000 ₫</span>
        </div>
        <div class="pkg-menu-item">
          <span class="pkg-menu-name mono"
            data-vi="Địa điểm thứ 3+"
            data-en="3rd location+">Địa điểm thứ 3+</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <span class="pkg-menu-price"
            data-vi="+500.000 ₫ / địa điểm"
            data-en="+500.000 ₫ / location">+500.000 ₫ / địa điểm</span>
        </div>
        <div class="pkg-menu-item pkg-menu-item--contact">
          <span class="pkg-menu-name mono">Video highlight</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <a href="/contact" class="pkg-menu-price pkg-menu-price--link"
            data-vi="Liên hệ báo giá →"
            data-en="Inquire for pricing →">Liên hệ báo giá →</a>
        </div>
        <div class="pkg-menu-item pkg-menu-item--contact">
          <span class="pkg-menu-name mono"
            data-vi="Gói tùy chỉnh"
            data-en="Custom package">Gói tùy chỉnh</span>
          <span class="pkg-menu-dots" aria-hidden="true"></span>
          <a href="/contact" class="pkg-menu-price pkg-menu-price--link"
            data-vi="Liên hệ để thiết kế →"
            data-en="Contact us to design →">Liên hệ để thiết kế →</a>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ============================================================
     CAM KẾT
     ============================================================ -->
<section class="guarantee-section">
  <div class="wrap">
    <div class="guarantee-eyebrow mono reveal"
      data-vi="Lệch Studio cam kết"
      data-en="Lệch Studio guarantees">Lệch Studio cam kết</div>
    <div class="guarantee-grid stagger">
      <div class="guarantee-item reveal">
        <span class="guarantee-num mono">I</span>
        <h3 class="display guarantee-title"
          data-vi="MINH BẠCH GIÁ"
          data-en="TRANSPARENT PRICING">MINH BẠCH GIÁ</h3>
        <p class="guarantee-desc"
          data-vi="Giá niêm yết là giá cuối. Không phụ phí ẩn, không bất ngờ sau buổi chụp."
          data-en="Listed price is final. No hidden fees, no surprises after the shoot.">Giá niêm yết là giá cuối. Không phụ phí ẩn, không bất ngờ sau buổi chụp.</p>
      </div>
      <div class="guarantee-item reveal">
        <span class="guarantee-num mono">II</span>
        <h3 class="display guarantee-title"
          data-vi="ĐÚNG HẠN"
          data-en="ON TIME">ĐÚNG HẠN</h3>
        <p class="guarantee-desc"
          data-vi="Trễ giao ảnh quá 48h so với cam kết — hoàn 10% giá trị gói, không cần hỏi."
          data-en="Delivery more than 48h late — 10% refund, no questions asked.">Trễ giao ảnh quá 48h so với cam kết — hoàn 10% giá trị gói, không cần hỏi.</p>
      </div>
      <div class="guarantee-item reveal">
        <span class="guarantee-num mono">III</span>
        <h3 class="display guarantee-title"
          data-vi="SỬA LẠI MIỄN PHÍ"
          data-en="FREE REVISION">SỬA LẠI MIỄN PHÍ</h3>
        <p class="guarantee-desc"
          data-vi="1 lần chỉnh sửa màu sắc miễn phí trong 7 ngày sau khi nhận ảnh."
          data-en="One free color revision within 7 days of receiving your photos.">1 lần chỉnh sửa màu sắc miễn phí trong 7 ngày sau khi nhận ảnh.</p>
      </div>
      <div class="guarantee-item reveal">
        <span class="guarantee-num mono">IV</span>
        <h3 class="display guarantee-title"
          data-vi="TƯ VẤN MIỄN PHÍ"
          data-en="FREE CONSULT">TƯ VẤN MIỄN PHÍ</h3>
        <p class="guarantee-desc"
          data-vi="Chưa chắc về gói? Nhắn tin — Lệch Studio tư vấn trực tiếp không tính phí."
          data-en="Not sure which package? Message us — free direct consultation.">Chưa chắc về gói? Nhắn tin — Lệch Studio tư vấn trực tiếp không tính phí.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     FILM STRIP
     ============================================================ -->
<div class="pkg-filmstrip" aria-hidden="true">
  <div class="filmstrip-holes filmstrip-holes--top"></div>
  <div class="filmstrip-track-wrap">
    <div class="filmstrip-track" id="filmstrip-track">
      <% [
        {photo:'https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=800&h=500&fit=crop&auto=format&q=80', label:'Wedding · 2026'},
        {photo:'https://images.unsplash.com/photo-1573676048035-9c2a72b6a12a?w=800&h=500&fit=crop&auto=format&q=80', label:'Pre-wedding'},
        {photo:'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&h=500&fit=crop&auto=format&q=80', label:'Portrait'},
        {photo:'https://images.unsplash.com/photo-1608497275992-b04e06353862?w=800&h=500&fit=crop&auto=format&q=80', label:'Fashion'},
        {photo:'https://images.unsplash.com/photo-1527529482837-4698179dc6ce?w=800&h=500&fit=crop&auto=format&q=80', label:'Event'},
        {photo:'https://images.unsplash.com/photo-1604017011826-d3b4c23f8914?w=800&h=500&fit=crop&auto=format&q=80', label:'BTS'},
        {photo:'https://images.unsplash.com/photo-1690812063433-36b580074b8b?w=800&h=500&fit=crop&auto=format&q=80', label:'Street'},
        {photo:'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=800&h=500&fit=crop&auto=format&q=80', label:'Brand'},
        {photo:'https://images.unsplash.com/photo-1532712938310-34cb3982ef74?w=800&h=500&fit=crop&auto=format&q=80', label:'Wedding · HN'},
        {photo:'https://images.unsplash.com/photo-1525284890203-9ee752d3f44f?w=800&h=500&fit=crop&auto=format&q=80', label:'Maternity'}
      ].concat([
        {photo:'https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=800&h=500&fit=crop&auto=format&q=80', label:'Wedding · 2026'},
        {photo:'https://images.unsplash.com/photo-1573676048035-9c2a72b6a12a?w=800&h=500&fit=crop&auto=format&q=80', label:'Pre-wedding'},
        {photo:'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&h=500&fit=crop&auto=format&q=80', label:'Portrait'},
        {photo:'https://images.unsplash.com/photo-1608497275992-b04e06353862?w=800&h=500&fit=crop&auto=format&q=80', label:'Fashion'},
        {photo:'https://images.unsplash.com/photo-1527529482837-4698179dc6ce?w=800&h=500&fit=crop&auto=format&q=80', label:'Event'},
        {photo:'https://images.unsplash.com/photo-1604017011826-d3b4c23f8914?w=800&h=500&fit=crop&auto=format&q=80', label:'BTS'},
        {photo:'https://images.unsplash.com/photo-1690812063433-36b580074b8b?w=800&h=500&fit=crop&auto=format&q=80', label:'Street'},
        {photo:'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=800&h=500&fit=crop&auto=format&q=80', label:'Brand'},
        {photo:'https://images.unsplash.com/photo-1532712938310-34cb3982ef74?w=800&h=500&fit=crop&auto=format&q=80', label:'Wedding · HN'},
        {photo:'https://images.unsplash.com/photo-1525284890203-9ee752d3f44f?w=800&h=500&fit=crop&auto=format&q=80', label:'Maternity'}
      ]).forEach((f,i) => { %>
      <div class="filmstrip-frame">
        <span class="filmstrip-frame-num mono"><%= String(i % 10 + 1).padStart(2,'0') %></span>
        <div class="filmstrip-img" style="background-image:url('<%= f.photo %>')"></div>
        <span class="filmstrip-label mono"><%= f.label %></span>
      </div>
      <% }) %>
    </div>
  </div>
  <div class="filmstrip-holes filmstrip-holes--bot"></div>
</div>

<!-- ============================================================
     FAQ
     ============================================================ -->
<section class="section-pad faq-section">
  <div class="wrap faq-wrap">
    <div class="section-head reveal">
      <span class="eyebrow"
        data-vi="Câu hỏi thường gặp"
        data-en="Frequently asked questions">Câu hỏi thường gặp</span>
      <h2 class="display section-title">FAQ.</h2>
    </div>
    <div class="faq-list">
      <% const faqs = [
        {
          q:  'Tôi cần đặt cọc bao nhiêu?',
          en: 'How much deposit do I need?',
          a:  '50% giá trị gói để xác nhận lịch. Phần còn lại thanh toán trước hoặc ngay sau buổi chụp.',
          ea: '50% of the package price to confirm the booking. The remainder is due before or right after the shoot.'
        },
        {
          q:  'Nếu hủy lịch thì sao?',
          en: 'What if I cancel?',
          a:  'Hủy trước 7 ngày — hoàn cọc 100%. Hủy trong 3–7 ngày — hoàn 50%. Hủy dưới 3 ngày — không hoàn cọc (trừ bất khả kháng).',
          ea: 'Cancel 7+ days before — full refund. 3–7 days before — 50% refund. Under 3 days — no refund (except force majeure).'
        },
        {
          q:  'Bao lâu thì nhận được ảnh?',
          en: 'How long until I receive my photos?',
          a:  'Standard 10 ngày · Signature 7 ngày · Premium 5 ngày làm việc. Ảnh giao qua Google Drive private link.',
          ea: 'Standard 10 days · Signature 7 days · Premium 5 business days. Delivered via private Google Drive link.'
        },
        {
          q:  'Tôi có được chọn ảnh không?',
          en: 'Can I select the photos myself?',
          a:  'Không — điều đó thường kéo dài thời gian và làm giảm chất lượng bộ ảnh. Lệch Studio chọn những tấm đẹp nhất đúng phong cách đã thống nhất.',
          ea: 'No — client selection often delays delivery and dilutes the set\'s quality. Lệch Studio curates the best shots true to your agreed style.'
        },
        {
          q:  'Có chụp ngoài Sài Gòn không?',
          en: 'Do you shoot outside Saigon?',
          a:  'Có. Hà Nội và Đà Nẵng mỗi tháng 1–2 chuyến. Tỉnh khác liên hệ để biết lịch gần nhất.',
          ea: 'Yes. Hanoi and Da Nang 1–2 trips per month. Other cities — contact us for the next available date.'
        },
        {
          q:  'Định dạng ảnh giao là gì?',
          en: 'What file format are the photos delivered in?',
          a:  'File JPG độ phân giải cao (thường 4000px+), đã chỉnh màu hoàn chỉnh. Premium bao gồm file RAW theo yêu cầu.',
          ea: 'High-resolution JPG files (typically 4000px+), fully color-graded. Premium includes RAW files on request.'
        }
      ] %>
      <% faqs.forEach((f, i) => { %>
      <details class="faq-item reveal">
        <summary class="faq-q">
          <span class="faq-num mono">0<%= i+1 %></span>
          <span class="faq-q-text" data-vi="<%= f.q %>" data-en="<%= f.en %>"><%= f.q %></span>
          <span class="faq-icon" aria-hidden="true"></span>
        </summary>
        <p class="faq-a" data-vi="<%= f.a %>" data-en="<%= f.ea %>"><%= f.a %></p>
      </details>
      <% }) %>
    </div>
  </div>
</section>

<!-- ============================================================
     CTA
     ============================================================ -->
<section class="cta-band">
  <div class="wrap cta-grid">
    <h2 class="display reveal"
      data-vi="CÒN THẮC MẮC?<br>CỨ HỎI THẲNG."
      data-en="STILL UNSURE?<br>JUST ASK.">CÒN THẮC MẮC?<br>CỨ HỎI THẲNG.</h2>
    <div class="reveal">
      <p class="hero-sub" style="color:var(--bone-dim);"
        data-vi="Lệch Studio trả lời trong 2 giờ trong giờ làm việc."
        data-en="Lệch Studio replies within 2 hours during business hours.">Lệch Studio trả lời trong 2 giờ trong giờ làm việc.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;">
        <a href="/booking" class="btn btn-on-dark"
          data-vi="Đặt lịch ngay →"
          data-en="Book now →">Đặt lịch ngay →</a>
        <a href="/contact" class="btn btn-ghost" style="border-color:var(--volt);color:var(--volt);"
          data-vi="Nhắn tin"
          data-en="Message us">Nhắn tin</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/script.js"></script>
</body>
</html>
